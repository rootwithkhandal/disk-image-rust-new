{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ForgeLens",
  "version": "0.1.0",
  "identifier": "com.forgelens.app",
  "build": {
    "frontendDist": "./ui",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "ForgeLens Memory Forensic Terminal",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
